{
  "name": "AZ Clean Auto Chunk Sorter",
  "short_name": "AZ Clean",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#0b1020",
  "theme_color": "#111827",
  "description": "Offline iPad app for cleaning, deduplicating, and sorting alliteration text into A-Z buckets.",
  "icons": [],
  "share_target": {
    "action": "./index.html?shared=1",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "text/plain": [".txt", ".text"],
        "text/markdown": [".md"],
        "text/html": [".html", ".htm"],
        "text/rtf": [".rtf"],
        "application/rtf": [".rtf"]
      }
    }
  ]
}
